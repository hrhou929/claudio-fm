# ================================================================
# Claudio FM 配置文件
# 复制此文件为 .env，然后运行 npm start 即可
# cp .env.example .env
# ================================================================

# ---------------- 端口 ----------------
CLAUDIO_PORT=8888

# ---------------- LLM ----------------
LLM_PROVIDER=openai_compat
OPENAI_COMPAT_API_KEY=sk-kWLTp5xrkyyMM2VyE5Ba0eAa196f4e1e94C42fEe0475De6e
OPENAI_COMPAT_BASE_URL=https://api.vveai.com/v1
OPENAI_COMPAT_MODEL=claude-sonnet-4-6

# ---------------- TTS 语音合成 ----------------
# 推荐：火山引擎豆包语音（中文效果最好，需在 console.volcengine.com 申请）
TTS_PROVIDER=volcengine
VOLCENGINE_TTS_API_KEY=你的_火山引擎_API_Key
VOLCENGINE_TTS_RESOURCE_ID=volc.service_type.10029
VOLCENGINE_TTS_VOICE_TYPE=zh_female_wanwanxiaohe_moon_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000

# 备用：OpenAI TTS（英文效果好，中文一般）
# TTS_PROVIDER=openai_tts
# OPENAI_TTS_VOICE=shimmer
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_SPEED=0.9

# ---------------- 音乐源 ----------------
MUSIC_PROVIDER=netease
NETEASE_API_BASE=http://127.0.0.1:3000
NETEASE_LEVEL=standard
NETEASE_COOKIE=
NETEASE_SIDECAR_COMMAND=node
NETEASE_SIDECAR_ARGS=node_modules/NeteaseCloudMusicApi/app.js
NETEASE_READY_TIMEOUT_MS=30000
